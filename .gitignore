# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Distribution / packaging
build/
dist/
*.egg-info/

# Jupyter Notebook
.ipynb_checkpoints/

# Data
data/
# cattle_dataset/processed/ holds only generated artifacts (02_prepare_vandenberg.py
# output: Geno/Pheno CSVs, metadata, QC report, log) — keep them local
cattle_dataset/processed/*
!cattle_dataset/processed/.gitkeep
# Runtime inputs — users drop their own Geno.csv / Pheno.csv here; keep them local
input/*.csv

# Results folder (removed - using array folders instead)
results/

# Log files
logs/
*.log
*.out
*.err

# OS files
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/

# Large files
*.pkl
*.pickle
*.h5
*.hdf5
*.parquet
*.feather
*.zip
*.tar
*.tar.gz
*.gz
*.bz2
*.7z
*.rar
# Model files (very large - 2.6GB each)
*.joblib
*.model
*.sav

# Array folders - track .csv, ignore logs and other files
# Benchmarking array: track .csv files
benchmarking_array/*.log
benchmarking_array/*.pkl
benchmarking_array/*.sh
benchmarking_array/job_*.pkl
benchmarking_array/shared_data_*.pkl
# Explicitly track CSV files
!benchmarking_array/*.csv

# Deployment array: ignore everything including models (models are too large for git)
# Models should be generated locally, not committed to repository
deployment_array/*.log
deployment_array/*.pkl
deployment_array/*.sh
deployment_array/*.json
deployment_array/job_*.pkl
deployment_array/shared_data_*.pkl
deployment_array/validation/
deployment_array/predictions/
deployment_array/models/
# Only track CSV summary files
!deployment_array/*.csv

# Prediction array: track .csv files, ignore logs
prediction_array/*.log
prediction_array/*.pkl
prediction_array/*.sh
prediction_array/job_*.pkl
prediction_array/shared_data_*.pkl
prediction_array/pred_results_*.pkl
# Explicitly track CSV files (prediction results)
!prediction_array/*.csv

# Generated pipeline outputs — created at runtime, keep local (never tracked)
Phase1_Learning_Benchmarking/
Phase2_Deployment_Prediction/
notebooks/
*.npy
*.npz
*.vcf
*.vcf.gz
*.tbi
*.tar
runs/
plans/
# test artifacts written into the repo root by tests/test_planner_routing.py
tmp_test_plan/
tmp_test_plan_rnd/
.pytest_cache/

# BGLR scratch outputs
scripts/*.dat
ETA_*.dat
mu.dat
varE.dat
